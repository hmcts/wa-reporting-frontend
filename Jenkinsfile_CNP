#!groovy

@Library("Infrastructure")

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [
    $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

def type = "nodejs"
def product = "wa"
def component = "reporting-frontend"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

env.AUTH_ENABLED="false"

withPipeline(type, product, component) {
  def archiveTestReports = {
    steps.archiveArtifacts(
      allowEmptyArchive: true,
      artifacts: 'test-results/**/*,playwright-report/**/*,functional-output/**/*,smoke-output/**/*'
    )
  }

  def runFlywayMigration = { String environmentName ->
    withAzureKeyvault(
      azureKeyVaultSecrets: [
        secret('cft-task-POSTGRES-USER-FLEXIBLE-REPLICA', 'TM_DB_MIGRATION_USER'),
        secret('cft-task-POSTGRES-PASS-FLEXIBLE-REPLICA', 'TM_DB_MIGRATION_PASSWORD')
      ],
      keyVaultURLOverride: "https://wa-${environmentName}.vault.azure.net/"
    ) {
      env.TM_DB_REPLICA_HOST = "cft-task-postgres-db-flexible-replica-${environmentName}.postgres.database.azure.com"

      sh '''
      set -eu
      cd db/flyway
      ./gradlew --no-daemon \
        -Dflyway.url="jdbc:postgresql://${TM_DB_REPLICA_HOST}:5432/cft_task_db?sslmode=verify-full" \
        -Dflyway.user="${TM_DB_MIGRATION_USER}" \
        -Dflyway.password="${TM_DB_MIGRATION_PASSWORD}" \
        flywayValidate flywayMigrate
      '''
    }
  }

  afterSuccess('build') {
    yarnBuilder.yarn('playwright install')
    yarnBuilder.yarn('rebuild puppeteer')
    yarnBuilder.yarn('build')
  }

  afterSuccess('test') {
    yarnBuilder.yarn('test:routes')
  }

  afterSuccess('buildinfra:aat') {
    runFlywayMigration('aat')
  }

  afterSuccess('buildinfra:demo') {
    runFlywayMigration('demo')
  }

  afterSuccess('buildinfra:ithc') {
    runFlywayMigration('ithc')
  }

  afterSuccess('buildinfra:perftest') {
    runFlywayMigration('perftest')
  }

  afterSuccess('buildinfra:prod') {
    runFlywayMigration('prod')
  }

  afterAlways('test') {
    archiveTestReports()
  }

  afterAlways('smoketest:preview') {
    archiveTestReports()
  }

  afterAlways('smoketest:aat') {
    archiveTestReports()
  }

  afterAlways('functionalTest:preview') {
    archiveTestReports()
  }

  afterAlways('functionalTest:aat') {
    archiveTestReports()
  }
}
